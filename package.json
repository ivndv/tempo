{
	"name": "pomodoro",
	"type": "module",
	"packageManager": "bun@1.3.9",
	"version": "0.0.1",
	"scripts": {
		"dev": "astro dev",
		"dev:full": "wrangler pages dev --compatibility-date=2026-04-30 --ip 127.0.0.1 --port 4321 --persist",
		"prebuild": "bun install",
		"build": "astro build",
		"preview": "astro preview",
		"astro": "astro",
		"format": "biome format --write .",
		"lint": "biome lint --write .",
		"check": "biome check --write .",
		"test": "vitest run",
		"gen:secret": "bun -e \"console.log(require('crypto').randomBytes(32).toString('hex'))\""
	},
	"overrides": {
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0"
	},
	"dependencies": {
		"@astrojs/cloudflare": "^13.3.1",
		"@astrojs/react": "^5.0.4",
		"@astrojs/sitemap": "^3.7.2",
		"@better-auth/utils": "^0.4.0",
		"@fontsource/outfit": "^5.2.8",
		"@iconify-json/lucide": "^1.2.105",
		"@iconify/react": "^6.0.2",
		"@marsidev/react-turnstile": "^1.5.2",
		"@tailwindcss/vite": "^4.2.4",
		"astro": "^6.2.2",
		"astro-icon": "^1.1.5",
		"bcryptjs": "^3.0.3",
		"better-auth": "latest",
		"drizzle-orm": "^0.45.2",
		"hono": "latest",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"tailwindcss": "^4.2.4"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.14",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/bcryptjs": "^3.0.0",
		"daisyui": "^5.5.19",
		"jsdom": "^29.1.1",
		"vitest": "^4.1.5"
	}
}
