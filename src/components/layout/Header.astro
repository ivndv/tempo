---
// Astro
import { getRelativeLocaleUrl } from "astro:i18n";
// i18n
import { useTranslations } from "../../i18n/utils";
// Componentes
import LanguagePicker from "./LanguagePicker.astro";
import AuthButton from "../Auth/AuthButton";
import ThemeToggle from "../ui/ThemeToggle.astro";
import MobileMenu from "./MobileMenu.astro";

// 1. Obtiene el idioma actual de la URL
const currentLang: 'es' | 'en' = (Astro.currentLocale === 'en' ? 'en' : 'es');
// 2. Inicializa las traducciones
const t = useTranslations(currentLang);
// 3. Verifica si la ruta actual coincide con la del link de navegación
const isActive = (path: string) => {
  return Astro.url.pathname === getRelativeLocaleUrl(currentLang, path);
};
---

<header class="w-full border-b border-base-200/50">
  <nav class="max-w-7xl mx-auto px-6 flex items-center justify-between">
    <!-- Logo -->
    <div class="flex items-center gap-2">
      <a
        href={getRelativeLocaleUrl(currentLang, "/")}
        class="flex items-center gap-2 group transition-transform hover:scale-105"
      >
        <span class="text-2xl">🍅</span>
        <span
          class="text-xl font-black bg-linear-to-r from-(--hero-title-from) to-(--hero-title-to) bg-clip-text text-transparent tracking-tighter"
        >
          Tempo
        </span>
      </a>
    </div>

    <!-- Desktop Nav Links -->
    <div class="hidden lg:flex items-center gap-8">
      <a
        href={getRelativeLocaleUrl(currentLang, "about")}
        class={`
          text-sm font-medium tracking-normal transition-all duration-200 border-b-2 pb-1
          ${isActive('about')
            ? 'opacity-100 border-primary text-primary'
            : 'opacity-60 hover:opacity-100 border-transparent'}
        `}
      >
        {t("nav.about")}
      </a>
      <a
        href={getRelativeLocaleUrl(currentLang, "blog")}
        class={`
          text-sm font-medium tracking-normal transition-all duration-200 border-b-2 pb-1
          ${isActive('blog')
            ? 'opacity-100 border-primary text-primary'
            : 'opacity-60 hover:opacity-100 border-transparent'}
        `}
      >
        {t("nav.blog")}
      </a>
    </div>

    <!-- Desktop Actions -->
    <div class="hidden lg:flex items-center gap-1">
      <ThemeToggle />
      <LanguagePicker />
      <AuthButton
        client:only="react"
        loginUrl={getRelativeLocaleUrl(currentLang, "login")}
      />
    </div>

    <!-- Mobile Actions -->
    <div class="flex lg:hidden items-center gap-2">
      <AuthButton
        client:only="react"
        loginUrl={getRelativeLocaleUrl(currentLang, "login")}
      />
      <MobileMenu lang={currentLang} />
    </div>
  </nav>
</header>
