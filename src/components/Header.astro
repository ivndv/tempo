---
import { getRelativeLocaleUrl } from "astro:i18n";
import { useTranslations } from "../i18n/utils";
import LanguagePicker from "./LanguagePicker.astro";
import AuthButton from "./AuthButton";
import ThemeToggle from "./ThemeToggle.astro";
import MobileMenu from "./MobileMenu.astro";

const currentLang: 'es' | 'en' = (Astro.currentLocale === 'en' ? 'en' : 'es');
const t = useTranslations(currentLang);

const isActive = (path: string) => {
  return Astro.url.pathname === getRelativeLocaleUrl(currentLang, path);
};
---

<header class="w-full py-6 border-b border-base-200/50 transition-all duration-400 sticky top-0 z-50">
  <nav class="max-w-7xl mx-auto px-6 flex items-center justify-between">
    <!-- Logo -->
    <div class="flex items-center gap-2">
      <a
        href={getRelativeLocaleUrl(currentLang, "/")}
        class="flex items-center gap-2 group transition-transform hover:scale-105"
      >
        <span class="text-2xl">🍅</span>
        <span
          class="text-xl font-black bg-linear-to-r from-(--hero-title-from) to-(--hero-title-to) bg-clip-text text-transparent tracking-tighter"
        >
          Tempo
        </span>
      </a>
    </div>

    <!-- Desktop Nav Links -->
    <div class="hidden lg:flex items-center gap-8">
      <a
        href={getRelativeLocaleUrl(currentLang, "about")}
        class={`
          text-sm font-medium tracking-normal transition-all duration-200 border-b-2 pb-1
          ${isActive('about')
            ? 'opacity-100 border-primary text-primary'
            : 'opacity-60 hover:opacity-100 border-transparent'}
        `}
      >
        {t("nav.about")}
      </a>
      <a
        href={getRelativeLocaleUrl(currentLang, "blog")}
        class={`
          text-sm font-medium tracking-normal transition-all duration-200 border-b-2 pb-1
          ${isActive('blog')
            ? 'opacity-100 border-primary text-primary'
            : 'opacity-60 hover:opacity-100 border-transparent'}
        `}
      >
        {t("nav.blog")}
      </a>
    </div>

    <!-- Desktop Actions -->
    <div class="hidden lg:flex items-center gap-1">
      <ThemeToggle />
      <LanguagePicker />
      <AuthButton
        client:only="react"
        loginText={currentLang === "es" ? "Entrar" : "Login"}
        logoutText={currentLang === "es" ? "Salir" : "Logout"}
        loginUrl={getRelativeLocaleUrl(currentLang, "login")}
      />
    </div>

    <!-- Mobile Actions -->
    <div class="flex lg:hidden items-center gap-2">
      <AuthButton
        client:only="react"
        loginText={currentLang === "es" ? "Entrar" : "Login"}
        logoutText={currentLang === "es" ? "Salir" : "Logout"}
        loginUrl={getRelativeLocaleUrl(currentLang, "login")}
      />
      <MobileMenu lang={currentLang} />
    </div>
  </nav>
</header>
