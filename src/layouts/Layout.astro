---
// Astro
import { ClientRouter } from 'astro:transitions';
// Estilos
import '../styles/global.css';
// Componentes
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import SessionProvider from '../components/session/SessionProvider.tsx';
// Fuentes
import '@fontsource/outfit';

// 1. Props del layout principal
interface Props {
	title: string;
	description?: string;
	image?: string;
    lang?: string;
}

// 2. Valores por defecto de props
const {
	title = "Tempo",
	description = "Maximiza tu productividad y concentración. La herramienta ideal para estudiantes, profesionales y creativos que buscan enfoque total.",
	image = "https://pomodoro-assets.mgdc.site/og-image.png",
    lang = "es"
} = Astro.props;

// 3. Descripción JSON-LD según el idioma
const jsonLdDescription = lang === 'en'
    ? "A minimalist Pomodoro timer designed to improve productivity and focus."
    : "Un temporizador Pomodoro minimalista diseñado para mejorar la productividad y el enfoque.";
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="https://pomodoro-assets.mgdc.site/favicon.png" />
		<meta name="generator" content={Astro.generator} />

		<!-- SEO y metadatos -->
		<title>{title}</title>
		<meta name="robots" content="index, follow" />
		<link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
		<meta name="keywords" content="tempo, pomodoro, timer, focus, productivity, study, work, technique, tomato, temporizador, enfoque, productividad, estudio, trabajo, tecnica" />
		<!-- Idiomas alternativos -->
		<link rel="alternate" hreflang="x-default" href="https://tempo.mgdc.site" />
		<link rel="alternate" hreflang="es" href="https://tempo.mgdc.site" />
		<link rel="alternate" hreflang="en" href="https://tempo.mgdc.site/en" />

		<ClientRouter />
		<!-- Umami Analytics -->
		<script defer src="https://umami.fluxdv.icu/script.js" data-website-id="933a5505-2604-4ea0-9870-1313b25d5827"></script>
		<script is:inline>
			// 1. Obtiene el tema guardado o el del sistema
			const getTheme = () => {
				if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
					return localStorage.getItem('theme');
				}
				if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
					return 'business';
				}
				return 'nord';
			};

			// 2. Aplica el tema al DOM y lo persiste en localStorage
			const applyTheme = (theme) => {
				document.documentElement.setAttribute('data-theme', theme);
				if (theme === 'business') {
					document.documentElement.classList.add('dark');
				} else {
					document.documentElement.classList.remove('dark');
				}
				localStorage.setItem('theme', theme);

				// 2a. Sincroniza el estado del checkbox si existe
				const controller = document.querySelector('.theme-controller');
				if (controller) {
					controller.checked = theme === 'business';
				}
			};

			// 3. Inicializa inmediatamente para evitar FOUC
			const currentTheme = getTheme();
			applyTheme(currentTheme);
			document.documentElement.setAttribute('data-theme-initialized', 'true');

			// 4. Event listeners para persistencia en cada navegación
			const onPageLoad = () => {
				const theme = getTheme();
				applyTheme(theme);

				const controller = document.querySelector('.theme-controller');
				if (controller) {
					controller.checked = theme === 'business';
					controller.addEventListener('change', (e) => {
						const newTheme = e.target.checked ? 'business' : 'nord';
						applyTheme(newTheme);
					});
				}

				// 4a. Detecta scroll para cambiar estilo del header
				const headerScroll = () => {
					const header = document.querySelector('header');
					if (!header) return;
					if (window.scrollY > 30) {
						header.classList.add('header-scrolled');
					} else {
						header.classList.remove('header-scrolled');
					}
				};
				headerScroll();
				window.addEventListener('scroll', headerScroll, { passive: true });
			};

			document.addEventListener('astro:page-load', onPageLoad);
			document.addEventListener('astro:after-swap', () => {
				applyTheme(getTheme());
				// 4b. Revisa estado del header después del cambio de página
				const header = document.querySelector('header');
				if (header) {
					if (window.scrollY > 30) {
						header.classList.add('header-scrolled');
					} else {
						header.classList.remove('header-scrolled');
					}
				}
			});
		</script>

		<meta name="description" content={description} />

		<!-- Schema.org JSON-LD -->
		<script type="application/ld+json" set:html={JSON.stringify({
			  "@context": "https://schema.org",
			  "@type": "SoftwareApplication",
			  "name": "Tempo",
			  "operatingSystem": "Any",
			  "applicationCategory": "ProductivityApplication",
			  "offers": {
				"@type": "Offer",
				"price": "0",
				"priceCurrency": "USD"
			  },
			  "description": jsonLdDescription,
              "inLanguage": lang
			})}>
		</script>

		<!-- Open Graph -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:image" content={image} />
		<meta property="og:url" content={Astro.url} />
		<!-- Twitter Cards -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={image} />
	</head>
	<body class="min-h-screen flex flex-col antialiased">
		<SessionProvider client:only="react" />
		<Header />
		<main class="grow w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
			<slot />
		</main>
		<Footer />
	</body>
</html>
