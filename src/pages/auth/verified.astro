---
// Layout
import Layout from '../../layouts/Layout.astro';
// i18n
import { useTranslations } from '../../i18n/utils';

const lang = (Astro.currentLocale || 'es') as 'es' | 'en';
const t = useTranslations(lang);
---

<Layout title="Email verificado | Tempo">
	<div class="min-h-screen flex items-center justify-center py-8 px-4">
		<div class="text-center space-y-6 animate-fade-in-up max-w-md">
			<div class="text-7xl">✅</div>
			<h1 class="text-3xl font-black">
				{t("auth.verified.title")}
			</h1>
			<p class="text-base-content/70 text-lg">
				{t("auth.verified.message")}
			</p>
			<a href={lang === 'en' ? '/en/login' : '/login'} data-astro-reload class="btn btn-primary btn-lg mt-4">
				{t("auth.verified.cta")}
			</a>
		</div>
	</div>
</Layout>
